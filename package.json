{
  "name": "vigie",
  "version": "0.1.0",
  "private": true,
  "description": "Vigie — application mobile anti-arnaque (monorepo)",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/api",
    "apps/mobile",
    "packages/shared"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc --noEmit -p scripts",
    "test": "npm run test --workspaces --if-present",
    "check": "npm run lint && npm run typecheck && npm run test",
    "eval": "tsx scripts/eval.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "unrs-resolver@1.12.2": true
  }
}
