{
  "name": "@vigie/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend Hono de Vigie",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --packages=external --outfile=dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "eval:corpus": "tsx src/ai/eval/run.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@hono/node-server": "^2.0.8",
    "@vigie/shared": "*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "pg": "^8.22.0",
    "undici": "^8.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.5"
  }
}
