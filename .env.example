# ============================================================
# Vigie — variables d'environnement
# Copier ce fichier en `.env` et remplir les valeurs manquantes.
# Ne JAMAIS commiter le fichier `.env`.
# ============================================================

# --- Base de données (Postgres local via docker-compose) ---
POSTGRES_USER=vigie
POSTGRES_PASSWORD=vigie_local_dev
POSTGRES_DB=vigie
DATABASE_URL=postgresql://vigie:vigie_local_dev@localhost:5432/vigie

# --- API backend ---
PORT=3000
# Origine autorisée par le CORS (URL du bundler Expo en dev)
CORS_ORIGIN=http://localhost:8081
# true uniquement derrière un proxy de confiance (Fly.io/Railway) :
# l'API lit alors l'IP client dans X-Forwarded-For pour le rate limiting.
TRUST_PROXY=false

# --- Moteur d'analyse IA ---
# MOCK_AI=true (défaut en dev) : /v1/analyze n'appelle JAMAIS l'API Anthropic ;
# le MockProvider renvoie des verdicts réalistes et déterministes selon le
# contenu soumis (voir README § Mode mock). Aucune clé API requise.
# MOCK_AI=false : AnthropicProvider est utilisé — ANTHROPIC_API_KEY obligatoire.
MOCK_AI=true
# Clé API : https://console.anthropic.com — jamais dans le code, jamais commitée.
ANTHROPIC_API_KEY=
# Modèle imposé par le cahier des charges (§5).
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Rate limiting (§6 du cahier des charges) ---
RATE_LIMIT_PER_HOUR=10
RATE_LIMIT_PER_DAY=30
