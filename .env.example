# ============================================================
# Vigie — variables d'environnement
# Copier ce fichier en `.env` et remplir les valeurs manquantes.
# Ne JAMAIS commiter le fichier `.env`.
# ============================================================

# --- Base de données (Postgres local via docker-compose) ---
POSTGRES_USER=vigie
POSTGRES_PASSWORD=vigie_local_dev
POSTGRES_DB=vigie
DATABASE_URL=postgresql://vigie:vigie_local_dev@localhost:5432/vigie

# --- API backend ---
PORT=3000
# Origine autorisée par le CORS (URL du bundler Expo en dev)
CORS_ORIGIN=http://localhost:8081

# --- Anthropic (obligatoire à partir de la Phase 1) ---
# Clé API : https://console.anthropic.com — jamais dans le code, jamais commitée.
ANTHROPIC_API_KEY=

# --- Rate limiting (§6 du cahier des charges) ---
RATE_LIMIT_PER_HOUR=10
RATE_LIMIT_PER_DAY=30
